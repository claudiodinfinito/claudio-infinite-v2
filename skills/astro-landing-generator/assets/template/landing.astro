---
import Layout from '../layouts/Layout.astro';

// TEMPLATE: Generic Landing Page Anatomy
// Customizable sections for any business
---

<Layout title="Landing Page Template" description="Professional landing page template">
  <main class="landing-template">
    
    <!-- 1. HERO SECTION -->
    <section class="hero-section">
      <div class="hero-content">
        <span class="badge">Badge Text Here</span>
        <h1>Compelling Headline That Grabs Attention</h1>
        <p class="hero-subtitle">Supporting text that explains your value proposition. Keep it clear and concise.</p>
        <div class="cta-group">
          <a href="#cta" class="btn-primary">Primary CTA</a>
          <a href="#features" class="btn-secondary">Learn More</a>
        </div>
        <div class="trust-badges">
          <span>⭐ 4.9/5 Rating</span>
          <span>👥 10,000+ Customers</span>
          <span>🏆 Award Winner</span>
        </div>
      </div>
      <div class="hero-image">
        <div class="image-placeholder">
          <span>🖼️</span>
          <p>Hero Image Placeholder</p>
        </div>
      </div>
    </section>

    <!-- 2. LOGOS/TRUST SECTION -->
    <section class="logos-section">
      <p>Trusted by leading companies</p>
      <div class="logos-grid">
        <div class="logo-placeholder">Logo 1</div>
        <div class="logo-placeholder">Logo 2</div>
        <div class="logo-placeholder">Logo 3</div>
        <div class="logo-placeholder">Logo 4</div>
        <div class="logo-placeholder">Logo 5</div>
      </div>
    </section>

    <!-- 3. FEATURES/BENEFITS -->
    <section id="features" class="features-section">
      <div class="section-header">
        <span class="section-badge">Features</span>
        <h2>Why Choose Us</h2>
        <p>Discover the benefits that set us apart</p>
      </div>
      <div class="features-grid">
        <div class="feature-card">
          <span class="feature-icon">🚀</span>
          <h3>Feature Title 1</h3>
          <p>Description of the first key benefit or feature that provides value to your customers.</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">💡</span>
          <h3>Feature Title 2</h3>
          <p>Description of the second key benefit or feature that solves a problem for users.</p>
        </div>
        <div class="feature-card">
          <span class="feature-icon">🎯</span>
          <h3>Feature Title 3</h3>
          <p>Description of the third key benefit that differentiates you from competitors.</p>
        </div>
      </div>
    </section>

    <!-- 4. HOW IT WORKS -->
    <section class="how-it-works-section">
      <div class="section-header">
        <span class="section-badge">Process</span>
        <h2>How It Works</h2>
        <p>Three simple steps to get started</p>
      </div>
      <div class="steps-grid">
        <div class="step">
          <div class="step-number">1</div>
          <h3>Step One</h3>
          <p>Brief description of the first step in your process.</p>
        </div>
        <div class="step-connector">→</div>
        <div class="step">
          <div class="step-number">2</div>
          <h3>Step Two</h3>
          <p>Brief description of the second step in your process.</p>
        </div>
        <div class="step-connector">→</div>
        <div class="step">
          <div class="step-number">3</div>
          <h3>Step Three</h3>
          <p>Brief description of the final step and outcome.</p>
        </div>
      </div>
    </section>

    <!-- 5. TESTIMONIALS -->
    <section class="testimonials-section">
      <div class="section-header">
        <span class="section-badge">Testimonials</span>
        <h2>What Our Customers Say</h2>
      </div>
      <div class="testimonials-grid">
        <div class="testimonial-card">
          <div class="testimonial-content">
            <span class="quote-icon">"</span>
            <p>This is a testimonial from a satisfied customer. It should be authentic, specific, and highlight the key benefits they experienced.</p>
          </div>
          <div class="testimonial-author">
            <div class="author-avatar">👤</div>
            <div class="author-info">
              <span class="author-name">Customer Name</span>
              <span class="author-title">Job Title, Company</span>
            </div>
          </div>
        </div>
        <div class="testimonial-card">
          <div class="testimonial-content">
            <span class="quote-icon">"</span>
            <p>Another testimonial showcasing the positive impact. Include specific results or metrics when possible for credibility.</p>
          </div>
          <div class="testimonial-author">
            <div class="author-avatar">👤</div>
            <div class="author-info">
              <span class="author-name">Customer Name</span>
              <span class="author-title">Job Title, Company</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- 6. PRICING -->
    <section class="pricing-section">
      <div class="section-header">
        <span class="section-badge">Pricing</span>
        <h2>Simple, Transparent Pricing</h2>
        <p>Choose the plan that fits your needs</p>
      </div>
      <div class="pricing-grid">
        <div class="pricing-card">
          <h3>Basic</h3>
          <div class="price">
            <span class="currency">$</span>
            <span class="amount">29</span>
            <span class="period">/mo</span>
          </div>
          <p class="plan-description">Perfect for getting started</p>
          <ul class="features-list">
            <li>✓ Feature 1</li>
            <li>✓ Feature 2</li>
            <li>✓ Feature 3</li>
          </ul>
          <a href="#cta" class="btn-outline">Get Started</a>
        </div>
        <div class="pricing-card popular">
          <span class="popular-badge">⭐ Most Popular</span>
          <h3>Pro</h3>
          <div class="price">
            <span class="currency">$</span>
            <span class="amount">79</span>
            <span class="period">/mo</span>
          </div>
          <p class="plan-description">Best for growing teams</p>
          <ul class="features-list">
            <li>✓ Everything in Basic</li>
            <li>✓ Feature 4</li>
            <li>✓ Feature 5</li>
            <li>✓ Feature 6</li>
          </ul>
          <a href="#cta" class="btn-primary">Get Started</a>
        </div>
        <div class="pricing-card">
          <h3>Enterprise</h3>
          <div class="price">
            <span class="currency">$</span>
            <span class="amount">199</span>
            <span class="period">/mo</span>
          </div>
          <p class="plan-description">For large organizations</p>
          <ul class="features-list">
            <li>✓ Everything in Pro</li>
            <li>✓ Feature 7</li>
            <li>✓ Feature 8</li>
            <li>✓ Custom solutions</li>
          </ul>
          <a href="#cta" class="btn-outline">Contact Sales</a>
        </div>
      </div>
    </section>

    <!-- 7. FAQ -->
    <section class="faq-section">
      <div class="section-header">
        <span class="section-badge">FAQ</span>
        <h2>Frequently Asked Questions</h2>
      </div>
      <div class="faq-list">
        <details class="faq-item">
          <summary class="faq-question">
            <span class="icon">→</span>
            What is your question number one?
          </summary>
          <div class="faq-answer">
            <p>This is the answer to question one. Provide clear, helpful information that addresses common concerns or objections.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">
            <span class="icon">→</span>
            What is your question number two?
          </summary>
          <div class="faq-answer">
            <p>This is the answer to question two. Keep it concise but comprehensive enough to be useful.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">
            <span class="icon">→</span>
            What is your question number three?
          </summary>
          <div class="faq-answer">
            <p>This is the answer to question three. Consider linking to relevant resources or contact information if more details are needed.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary class="faq-question">
            <span class="icon">→</span>
            What is your question number four?
          </summary>
          <div class="faq-answer">
            <p>This is the answer to question four. Use this space to overcome objections and provide reassurance.</p>
          </div>
        </details>
      </div>
    </section>

    <!-- 8. FINAL CTA -->
    <section id="cta" class="cta-section">
      <div class="cta-content">
        <h2>Ready to Get Started?</h2>
        <p>Join thousands of satisfied customers and transform your experience today.</p>
        <div class="cta-buttons">
          <a href="/contact" class="btn-primary large">Start Free Trial</a>
          <a href="/contact" class="btn-secondary large">Schedule Demo</a>
        </div>
        <p class="cta-note">No credit card required • 14-day free trial</p>
      </div>
    </section>

    <!-- 9. FOOTER -->
    <footer class="footer">
      <div class="footer-content">
        <div class="footer-section">
          <h4>Product</h4>
          <a href="#features">Features</a>
          <a href="#pricing">Pricing</a>
          <a href="#faq">FAQ</a>
        </div>
        <div class="footer-section">
          <h4>Company</h4>
          <a href="/about">About</a>
          <a href="/contact">Contact</a>
          <a href="/blog">Blog</a>
        </div>
        <div class="footer-section">
          <h4>Legal</h4>
          <a href="#">Privacy Policy</a>
          <a href="#">Terms of Service</a>
        </div>
      </div>
      <div class="footer-bottom">
        <p>© 2026 Your Company. All rights reserved.</p>
      </div>
    </footer>

  </main>
</Layout>

<style>
  /* BASE STYLES */
  .landing-template {
    background: linear-gradient(180deg, #0a0a0f 0%, #1a1a2e 50%, #0a0a0f 100%);
    color: #fff;
    font-family: system-ui, -apple-system, sans-serif;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-badge {
    display: inline-block;
    background: linear-gradient(135deg, #00d4ff20, #7b2cbf20);
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    color: #00d4ff;
    border: 1px solid #00d4ff40;
    margin-bottom: 1rem;
  }

  .section-header h2 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .section-header p {
    color: #888;
    font-size: 1.1rem;
  }

  /* 1. HERO */
  .hero-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    padding: 4rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
    align-items: center;
    min-height: 90vh;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .badge {
    display: inline-block;
    background: linear-gradient(135deg, #00d4ff20, #7b2cbf20);
    padding: 0.5rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    border: 1px solid #00d4ff40;
    width: fit-content;
  }

  .hero-section h1 {
    font-size: 3.5rem;
    line-height: 1.1;
    background: linear-gradient(135deg, #fff, #00d4ff);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.2rem;
    color: #aaa;
    line-height: 1.6;
  }

  .cta-group {
    display: flex;
    gap: 1rem;
    margin-top: 1rem;
  }

  .btn-primary {
    background: linear-gradient(135deg, #00d4ff, #7b2cbf);
    color: #fff;
    padding: 1rem 2rem;
    border: none;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.2s, box-shadow 0.2s;
    display: inline-block;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 212, 255, 0.4);
  }

  .btn-primary.large {
    padding: 1.2rem 2.5rem;
    font-size: 1.1rem;
  }

  .btn-secondary {
    background: transparent;
    color: #00d4ff;
    padding: 1rem 2rem;
    border: 1px solid #00d4ff;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
    display: inline-block;
  }

  .btn-secondary:hover {
    background: #00d4ff20;
  }

  .btn-secondary.large {
    padding: 1.2rem 2.5rem;
    font-size: 1.1rem;
  }

  .btn-outline {
    background: transparent;
    color: #00d4ff;
    padding: 0.8rem 1.5rem;
    border: 1px solid #00d4ff;
    border-radius: 8px;
    font-size: 1rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
    display: block;
    text-align: center;
  }

  .btn-outline:hover {
    background: #00d4ff20;
  }

  .trust-badges {
    display: flex;
    gap: 1.5rem;
    margin-top: 2rem;
    font-size: 0.9rem;
    color: #888;
  }

  .hero-image {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .image-placeholder {
    background: linear-gradient(135deg, #1a1a2e, #2a2a3e);
    border: 2px dashed #ffffff20;
    border-radius: 20px;
    width: 100%;
    aspect-ratio: 4/3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .image-placeholder span {
    font-size: 4rem;
  }

  .image-placeholder p {
    color: #666;
  }

  /* 2. LOGOS */
  .logos-section {
    padding: 3rem 2rem;
    text-align: center;
    background: #ffffff03;
  }

  .logos-section > p {
    color: #888;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .logos-grid {
    display: flex;
    gap: 3rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .logo-placeholder {
    background: #ffffff10;
    padding: 1rem 2rem;
    border-radius: 8px;
    color: #888;
    font-size: 0.9rem;
  }

  /* 3. FEATURES */
  .features-section {
    padding: 5rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    background: #ffffff05;
    border: 1px solid #ffffff10;
    border-radius: 16px;
    padding: 2rem;
    text-align: center;
    transition: border-color 0.3s, transform 0.3s;
  }

  .feature-card:hover {
    border-color: #00d4ff40;
    transform: translateY(-4px);
  }

  .feature-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    margin-bottom: 0.5rem;
    font-size: 1.3rem;
  }

  .feature-card p {
    color: #aaa;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* 4. HOW IT WORKS */
  .how-it-works-section {
    padding: 5rem 2rem;
    background: #ffffff03;
  }

  .steps-grid {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    max-width: 1000px;
    margin: 0 auto;
    flex-wrap: wrap;
    justify-content: center;
  }

  .step {
    flex: 1;
    min-width: 200px;
    text-align: center;
    padding: 1rem;
  }

  .step-number {
    background: linear-gradient(135deg, #00d4ff, #7b2cbf);
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 auto 1rem;
  }

  .step h3 {
    margin-bottom: 0.5rem;
  }

  .step p {
    color: #aaa;
    font-size: 0.9rem;
  }

  .step-connector {
    font-size: 2rem;
    color: #00d4ff;
    padding-top: 2rem;
  }

  /* 5. TESTIMONIALS */
  .testimonials-section {
    padding: 5rem 2rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 2rem;
  }

  .testimonial-card {
    background: #ffffff05;
    border: 1px solid #ffffff10;
    border-radius: 16px;
    padding: 2rem;
  }

  .quote-icon {
    font-size: 3rem;
    color: #00d4ff;
    display: block;
    line-height: 1;
  }

  .testimonial-content p {
    color: #ccc;
    font-size: 1rem;
    line-height: 1.6;
    margin: 1rem 0;
  }

  .testimonial-author {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .author-avatar {
    width: 50px;
    height: 50px;
    background: #00d4ff20;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
  }

  .author-info {
    display: flex;
    flex-direction: column;
  }

  .author-name {
    font-weight: 600;
    font-size: 0.95rem;
  }

  .author-title {
    color: #888;
    font-size: 0.85rem;
  }

  /* 6. PRICING */
  .pricing-section {
    padding: 5rem 2rem;
    background: #ffffff03;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .pricing-card {
    background: #ffffff05;
    border: 1px solid #ffffff10;
    border-radius: 16px;
    padding: 2rem;
    position: relative;
    transition: transform 0.3s;
  }

  .pricing-card:hover {
    transform: translateY(-8px);
  }

  .pricing-card.popular {
    border-color: #00d4ff;
    box-shadow: 0 0 30px rgba(0, 212, 255, 0.2);
  }

  .popular-badge {
    position: absolute;
    top: -10px;
    right: 20px;
    background: linear-gradient(135deg, #00d4ff, #7b2cbf);
    padding: 0.3rem 1rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
  }

  .pricing-card h3 {
    font-size: 1.3rem;
    margin-bottom: 1rem;
  }

  .price {
    margin-bottom: 1rem;
  }

  .currency {
    font-size: 1.5rem;
    color: #888;
  }

  .amount {
    font-size: 3rem;
    font-weight: 700;
    background: linear-gradient(135deg, #00d4ff, #7b2cbf);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .period {
    color: #888;
    font-size: 1rem;
  }

  .plan-description {
    color: #888;
    margin-bottom: 1.5rem;
  }

  .features-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
  }

  .features-list li {
    padding: 0.5rem 0;
    color: #bbb;
  }

  /* 7. FAQ */
  .faq-section {
    padding: 5rem 2rem;
    max-width: 800px;
    margin: 0 auto;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .faq-item {
    background: #ffffff05;
    border: 1px solid #ffffff10;
    border-radius: 12px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .faq-item:hover {
    border-color: rgba(0, 212, 255, 0.2);
  }

  .faq-item[open] {
    border-color: #00d4ff;
  }

  .faq-question {
    padding: 1.2rem 1.5rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 1rem;
    list-style: none;
    font-weight: 500;
    color: #fff;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question .icon {
    color: #7b2cbf;
    transition: transform 0.3s;
    font-size: 0.9rem;
  }

  .faq-item[open] .faq-question .icon {
    transform: rotate(90deg);
    color: #00d4ff;
  }

  .faq-answer {
    padding: 0 1.5rem 1.5rem 3rem;
    color: #aaa;
    line-height: 1.7;
  }

  .faq-answer p {
    margin: 0;
  }

  /* 8. CTA */
  .cta-section {
    padding: 5rem 2rem;
    text-align: center;
    background: linear-gradient(135deg, #00d4ff10, #7b2cbf10);
  }

  .cta-content h2 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .cta-content > p {
    color: #aaa;
    font-size: 1.1rem;
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .cta-note {
    color: #888;
    font-size: 0.9rem;
  }

  /* 9. FOOTER */
  .footer {
    padding: 4rem 2rem 2rem;
    border-top: 1px solid #ffffff10;
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .footer-section h4 {
    margin-bottom: 1rem;
    color: #fff;
  }

  .footer-section a {
    display: block;
    color: #888;
    text-decoration: none;
    padding: 0.4rem 0;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .footer-section a:hover {
    color: #00d4ff;
  }

  .footer-bottom {
    text-align: center;
    padding-top: 2rem;
    margin-top: 2rem;
    border-top: 1px solid #ffffff10;
    color: #666;
    font-size: 0.85rem;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .hero-section {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }

    .hero-section h1 {
      font-size: 2.5rem;
    }

    .cta-group {
      justify-content: center;
      flex-wrap: wrap;
    }

    .trust-badges {
      justify-content: center;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .step-connector {
      display: none;
    }

    .cta-buttons {
      flex-direction: column;
